# Copy to .env and fill in values for local dev
# For a testnet production build, use CONTRACT_ADDRESS=0x... make build-ui instead

# Address of deployed PlaylistBounty (get from playlist-deployments.json after make deploy-playlist)
VITE_CONTRACT_ADDRESS=0x...

# RPC endpoint — defaults to Monad testnet; use localhost for local anvil dev
# VITE_RPC_URL=http://localhost:8545
# VITE_RPC_URL=https://testnet-rpc.monad.xyz
