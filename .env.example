# ── Wallet ────────────────────────────────────────────────────────────────────
# Your dev wallet private key — used by:
#   forge script (deploy-testnet)
#   agent loops  (loop-playlist, deploy-playlist in testnet mode)
PRIVATE_KEY=0x...
DEPLOYER_ADDRESS=0x...

# ── Monad testnet ─────────────────────────────────────────────────────────────
RPC_URL=https://testnet-rpc.monad.xyz
CHAIN_ID=10143

# Block explorer API key (optional, for contract verification)
ETHERSCAN_API_KEY=your_api_key_here

# ── Frontend build ────────────────────────────────────────────────────────────
# Set after deploying PlaylistBounty with `make deploy-testnet`
# Then run: CONTRACT_ADDRESS=0x... make build-ui
CONTRACT_ADDRESS=0x...

# Override the RPC URL baked into the static frontend build (optional)
# Defaults to https://testnet-rpc.monad.xyz
# VITE_RPC_URL=https://testnet-rpc.monad.xyz

# ── Local development ─────────────────────────────────────────────────────────
# For local dev against anvil, omit PRIVATE_KEY and CHAIN_ID.
# VITE_CONTRACT_ADDRESS and VITE_RPC_URL can be set in playlist-ui/.env:
#   VITE_CONTRACT_ADDRESS=0x...   (from playlist-deployments.json after deploy-playlist)
#   VITE_RPC_URL=http://localhost:8545

# ── Agent API ─────────────────────────────────────────────────────────────────
# Ollama model for LLM decisions (default: qwen3:1.7b)
# OLLAMA_MODEL=qwen3:1.7b
# OLLAMA_SEED=42
# OLLAMA_URL=http://localhost:11434

# DB path for Go API (default: contracts.db)
# DB_PATH=contracts.db
